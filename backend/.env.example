# Portalcrane Environment Configuration
# Copy this file to .env and adjust values

# ── Registry proxy (optional) ───────────────────────────────────────────────
REGISTRY_PROXY_AUTH_ENABLED=false

# ── Admin credentials ────────────────────────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

# ── Security ─────────────────────────────────────────────────────────────────
# Generate a strong random key: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-secret-key-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── OIDC (optional) ──────────────────────────────────────────────────────────
OIDC_ENABLED=false
OIDC_ISSUER=https://your-idp.example.com/realms/myrealm
OIDC_CLIENT_ID=portalcrane
OIDC_CLIENT_SECRET=your-client-secret
OIDC_REDIRECT_URI=http://localhost:8080/auth/callback

# OIDC-only mode: disable EVERY local login (including the built-in env-admin)
# and delegate authentication entirely to the OIDC provider. Only enable this
# once an admin path below is configured, otherwise nobody can obtain admin
# rights anymore (no break-glass).
OIDC_ONLY=false

# Admin bootstrap for OIDC users (re-evaluated on every SSO login) via
# group-claim mapping: grant admin when OIDC_ADMIN_GROUP is present in the
# claim named OIDC_ADMIN_GROUP_CLAIM (the scope must expose that claim).
OIDC_ADMIN_GROUP_CLAIM=
OIDC_ADMIN_GROUP=

# Regular-user mapping (optional): grant the regular-user role when
# OIDC_USER_GROUP is present in the claim named OIDC_USER_GROUP_CLAIM (the scope
# must expose that claim).
OIDC_USER_GROUP_CLAIM=
OIDC_USER_GROUP=

# Restrict access to mapped groups. When true, OIDC access becomes an allowlist:
# only admins and users matching the mappings above may log in. Any SSO user
# belonging to neither the admin nor the user group is denied and their account
# is NOT created. When false (default), every authenticated SSO user is admitted
# as a regular user regardless of their groups.
OIDC_RESTRICT_TO_GROUPS=false

# ── Reverse proxy & rate limiting (optional) ─────────────────────────────────
# CIDR ranges (or bare IPs, comma-separated) of the reverse proxies in front of
# the app. X-Forwarded-For / Forwarded / X-Real-IP headers are trusted to derive
# the real client IP ONLY when the request comes from one of these ranges;
# otherwise they are ignored (anti-spoofing) and the direct peer IP is used.
# This resolved IP keys both the audit log and the per-IP rate limiter below.
# Leave empty when the app is exposed directly (no reverse proxy).
TRUSTED_PROXIES=
# In-memory per-IP rate limiting on /api/* routes. Auth endpoints (login/token)
# use the stricter AUTH budget to throttle password brute-force.
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_LOGIN_MAX_ATTEMPTS=5

# ── HTTP Proxy (optional) ─────────────────────────────────────────────────────
# Used for outbound calls: Docker Hub API, OIDC discovery, and docker pull/push
# commands launched by the staging pipeline.
# Format: http://[user:password@]host:port
HTTP_PROXY=
HTTPS_PROXY=
# Hosts that bypass the proxy (comma-separated)
NO_PROXY=localhost,127.0.0.1

# ── Syslog forwarding (optional) ──────────────────────────────────────────────
# Forward audit and/or uvicorn logs to a remote syslog server. These values are
# defaults; a persisted override saved from the Network settings UI takes
# precedence over them.
SYSLOG_ENABLED=false
SYSLOG_HOST=
SYSLOG_PORT=514
# Transport: udp | tcp | tcp+tls
SYSLOG_PROTOCOL=udp
# Message format: rfc5424 | rfc3164
SYSLOG_RFC=rfc5424
SYSLOG_FORWARD_AUDIT=true
SYSLOG_FORWARD_UVICORN=false
# TLS options (only meaningful when SYSLOG_PROTOCOL=tcp+tls)
SYSLOG_TLS_VERIFY=true
SYSLOG_TLS_CA_CERT=
# Authentication (only over TCP — RFC 6587 / RELP)
SYSLOG_AUTH_ENABLED=false
SYSLOG_AUTH_USERNAME=
SYSLOG_AUTH_PASSWORD=

# ── Audit log by email (optional) ─────────────────────────────────────────────
# Deliver the audit log by email over SMTP. These values are defaults; a
# persisted override saved from the Network settings UI takes precedence.
EMAIL_ENABLED=false
EMAIL_HOST=
EMAIL_PORT=587
# Connection security: none | starttls | ssl
EMAIL_SECURITY=starttls
EMAIL_USERNAME=
EMAIL_PASSWORD=
EMAIL_FROM_ADDRESS=
# Recipients (comma-separated)
EMAIL_TO_ADDRESSES=
EMAIL_SUBJECT=Portalcrane audit log

# ── Vulnerability scanning (Trivy) ────────────────────────────────────────────
VULN_SCAN_ENABLED=true
VULN_SCAN_SEVERITIES=CRITICAL,HIGH, MEDIUM
VULN_IGNORE_UNFIXED=false
VULN_SCAN_TIMEOUT=5m

# ── Logging ─────────────────────────────────────────────────────────────────
SWAGGER_ENABLED=false
LOG_LEVEL=INFO
# ── Audit ───────────────────────────────────────────────────────────────────
# Maximum number of audit events retained on disk in DATA_DIR/audit-events.jsonl
AUDIT_MAX_EVENTS=100
